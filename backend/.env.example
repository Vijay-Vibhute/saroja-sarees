# Backend Environment Variables

## Copy this when setting up:

# ============================================================
# RAZORPAY CONFIGURATION
# ============================================================

# TEST MODE (for development)
# Get from: https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=rzp_test_abc123xyz
RAZORPAY_KEY_SECRET=your_test_secret_key_here

# PRODUCTION MODE (uncomment when going live)
# Replace with live keys from Razorpay
# RAZORPAY_KEY_ID=rzp_live_abc123xyz
# RAZORPAY_KEY_SECRET=your_live_secret_key_here

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Server port
PORT=3001

# Environment (development or production)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# ============================================================
# DATABASE (Optional - for storing orders)
# ============================================================

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/ratnaprabha_db

# MongoDB example:
# DATABASE_URL=mongodb://localhost:27017/ratnaprabha_db

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=info

# ============================================================
# EMAIL (Optional - for notifications)
# ============================================================

# SMTP credentials for transactional emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=admin@example.com

# ============================================================
# SECURITY
# ============================================================

# API Rate limiting (requests per minute)
# RATE_LIMIT=100

# ============================================================
# INSTRUCTIONS
# ============================================================

# 1. Copy this file content
# 2. Create new file: backend/.env
# 3. Paste content
# 4. Replace placeholder values with your actual keys
# 5. Save file
# 6. DO NOT commit .env to git
# 7. Restart backend server

# TEST CARD FOR RAZORPAY (in test mode)
# Card: 4111 1111 1111 1111
# Expiry: Any future date
# CVV: 123

# ============================================================
